{
  "cleanUrls": true,
  "build": {
    "env": {
      "NODE_VERSION": "22",
      "LC_ALL": "C.UTF-8",
      "LANG": "en_US.UTF-8",
      "LANGUAGE": "en_US.UTF-8"
    }
  },
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ]
}